{
  "compilerOptions": {
    "module": "nodenext",
    "target": "ES2020",
    "lib": ["ES2020"],
    "moduleResolution": "nodenext",
    "outDir": "out",
    "rootDir": "src",
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true
  },
  "exclude": ["node_modules", "out", "vitest.config.ts", "scripts"]
}
